# Server bind address and port.
# Keep MOOD_HOST as 127.0.0.1 when using Caddy as a reverse proxy.
MOOD_HOST=127.0.0.1
MOOD_PORT=5000

# Application security and storage.
# Copy this file to .env and replace the placeholder before deployment.
MOOD_SECRET_KEY=replace-with-a-random-secret-key
MOOD_DB_PATH=data/mood_barometer.sqlite3

# Optional development reload.
FASTAPI_RELOAD=0

# Optional first-run admin bootstrap for deploy-first-run.sh.
# The deploy script imports main.py, so these values can be loaded from .env.
# Set both nickname and password, or leave all admin values commented out.
# MOOD_ADMIN_NICKNAME=admin
# MOOD_ADMIN_NAME=Administrator
# MOOD_ADMIN_PASSWORD=change-this-password

# Optional deploy script service name.
# Note: deploy-first-run.sh reads this in bash before main.py loads .env,
# so set it as an exported shell variable if you need a custom service name:
# MOOD_SERVICE_NAME=techx-shude-mood-barometer.service
